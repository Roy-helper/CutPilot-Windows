# CutPilot 配置文件
# 复制此文件为 .env 并填入你的配置

# ── AI 供应商 ──
# 支持: deepseek, qwen, kimi, minimax, zhipu, custom
CUTPILOT_PROVIDER=deepseek
CUTPILOT_API_KEY=your_api_key_here
# 以下仅在 PROVIDER=custom 时需要
# CUTPILOT_BASE_URL=https://api.example.com/v1
# CUTPILOT_MODEL=your-model-name

# ── 处理参数 ──
CUTPILOT_MAX_VERSIONS=3
CUTPILOT_MIN_SENTENCES=15
CUTPILOT_GENERATE_FAST=true
CUTPILOT_VIDEO_QUALITY=standard

# ── Hook 文字叠加 ──
CUTPILOT_ENABLE_HOOK_OVERLAY=true
CUTPILOT_HOOK_DURATION=3.0

# ── 语音识别 ──
CUTPILOT_ENABLE_SPEAKER_DIARIZATION=true
# CUTPILOT_HOTWORDS=品牌名 产品名

# ── 输出 ──
# 留空则输出到视频所在目录的 output/ 子文件夹
# CUTPILOT_OUTPUT_DIR=/path/to/output
